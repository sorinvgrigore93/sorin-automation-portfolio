    {
      "parameters": {
        "content": "Sistema Automatizado de Reporting para E-commerce\nRecopila ventas, pedidos e incidencias desde Google Sheets y prepara un reporte operativo automático."
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        192,
        -432
      ],
      "id": "9b1cd023-c73f-4117-b25d-ec5b8e689cd4",
      "name": "Sticky Note"
    },
    {
      "parameters": {
        "content": "Fuentes de datos\nLee información desde las pestañas:\nVentas, Pedidos e Incidencias.",
        "height": 144,
        "width": 224
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -160,
        -176
      ],
      "id": "ad7fa2df-eef8-44fc-bc60-f3e8386bb348",
      "name": "Sticky Note1"
    },
    {
      "parameters": {
        "content": "Unificación de datos\nCombina ventas, pedidos e incidencias para calcular métricas del reporte.",
        "height": 128,
        "width": 224
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        640,
        176
      ],
      "id": "d90705fc-220b-435c-8cdf-d1114bc1d7c8",
      "name": "Sticky Note2"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all().map(item => item.json);\n\nconst ventas = items.filter(item => item.producto && item.cantidad);\nconst pedidos = items.filter(item => item.estado_pedido);\nconst incidencias = items.filter(item => item.incidencia_id);\n\nconst ventasTotales = ventas.reduce((sum, venta) => {\n  return sum + Number(venta.total || 0);\n}, 0);\n\nconst cantidadVentas = ventas.length;\nconst cantidadPedidos = pedidos.length;\n\nconst pedidosEnviados = pedidos.filter(pedido => \n  pedido.estado_pedido === 'enviado'\n).length;\n\nconst incidenciasTotales = incidencias.length;\n\nconst incidenciasAbiertas = incidencias.filter(incidencia => \n  incidencia.estado === 'abierta'\n).length;\n\nlet estadoGeneral = 'Estable';\n\nif (incidenciasAbiertas > 0) {\n  estadoGeneral = 'Revisar incidencias abiertas';\n}\n\nreturn [\n  {\n    json: {\n      fecha_reporte: new Date().toISOString().split('T')[0],\n      ventas_totales: ventasTotales,\n      cantidad_ventas: cantidadVentas,\n      cantidad_pedidos: cantidadPedidos,\n      pedidos_enviados: pedidosEnviados,\n      incidencias_totales: incidenciasTotales,\n      incidencias_abiertas: incidenciasAbiertas,\n      estado_general: estadoGeneral\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1056,
        -96
      ],
      "id": "e48ac9c4-16d4-4000-b88f-f3f8fa2c9033",
      "name": "Code | Calcular métricas del reporte"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst ventas = Number(data.ventas_totales || 0).toFixed(2);\n\nconst cuerpoHtml = `\n<div style=\"font-family: Arial, sans-serif; max-width: 650px; margin: 0 auto; color: #222;\">\n  <div style=\"background: #111827; color: white; padding: 20px; border-radius: 10px 10px 0 0;\">\n    <h2 style=\"margin: 0;\">📊 Reporte operativo diario</h2>\n    <p style=\"margin: 6px 0 0;\">E-commerce · ${data.fecha_reporte}</p>\n  </div>\n\n  <div style=\"border: 1px solid #e5e7eb; border-top: none; padding: 24px; border-radius: 0 0 10px 10px;\">\n    <h3 style=\"margin-top: 0;\">Resumen comercial</h3>\n\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px;\">\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\">Ventas totales</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; text-align: right;\"><strong>${ventas} €</strong></td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\">Número de ventas</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; text-align: right;\"><strong>${data.cantidad_ventas}</strong></td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\">Pedidos totales</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; text-align: right;\"><strong>${data.cantidad_pedidos}</strong></td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\">Pedidos enviados</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; text-align: right;\"><strong>${data.pedidos_enviados}</strong></td>\n      </tr>\n    </table>\n\n    <h3>Incidencias</h3>\n\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px;\">\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\">Incidencias totales</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; text-align: right;\"><strong>${data.incidencias_totales}</strong></td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\">Incidencias abiertas</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; text-align: right;\"><strong>${data.incidencias_abiertas}</strong></td>\n      </tr>\n    </table>\n\n    <div style=\"background: #fef3c7; border-left: 5px solid #f59e0b; padding: 14px; border-radius: 6px;\">\n      <strong>Estado general:</strong><br>\n      ${data.estado_general}\n    </div>\n\n    <p style=\"font-size: 12px; color: #6b7280; margin-top: 24px;\">\n      Reporte generado automáticamente con n8n.\n    </p>\n  </div>\n</div>\n`;\n\nreturn [\n  {\n    json: {\n      fecha_reporte: data.fecha_reporte,\n      asunto_email: `Reporte operativo diario e-commerce - ${data.fecha_reporte}`,\n      cuerpo_email: cuerpoHtml\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1264,
