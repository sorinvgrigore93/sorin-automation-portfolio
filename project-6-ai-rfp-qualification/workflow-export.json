    {
      "parameters": {
        "jsCode": "const rawOutput = $json.output?.[0]?.content?.[0]?.text || '';\n\nfunction extractJsonString(text) {\n  let cleaned = text.trim();\n\n  // Remove markdown code fences\n  cleaned = cleaned.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '');\n  cleaned = cleaned.replace(/\\s*```$/i, '');\n\n  // Remove leading/trailing triple backticks if still present\n  cleaned = cleaned.replace(/^'''json\\s*/i, '').replace(/\\s*'''$/i, '');\n\n  // Trim wrapping quotes only if the whole payload is quoted\n  if (\n    (cleaned.startsWith('\"') && cleaned.endsWith('\"')) ||\n    (cleaned.startsWith(\"'\") && cleaned.endsWith(\"'\"))\n  ) {\n    cleaned = cleaned.slice(1, -1);\n  }\n\n  // Find JSON block\n  const firstBrace = cleaned.indexOf('{');\n  const lastBrace = cleaned.lastIndexOf('}');\n\n  if (firstBrace === -1 || lastBrace === -1) {\n    throw new Error('No JSON object found in proposal draft response');\n  }\n\n  cleaned = cleaned.slice(firstBrace, lastBrace + 1);\n\n  // Normalize escaped sequences carefully\n  cleaned = cleaned\n    .replace(/\\r/g, '')\n    .replace(/\\\\n/g, '\\\\n')\n    .replace(/\\\\t/g, '\\\\t')\n    .replace(/\\\\\"/g, '\"');\n\n  return cleaned;\n}\n\ntry {\n  const jsonString = extractJsonString(rawOutput);\n  const parsed = JSON.parse(jsonString);\n\n  return [\n    {\n      json: {\n        proposalSubject: parsed.proposalSubject || 'Draft proposal',\n        proposalDraft: parsed.proposalDraft || '',\n        proposalRawResponse: rawOutput\n      }\n    }\n  ];\n} catch (error) {\n  return [\n    {\n      json: {\n        proposalSubject: 'Draft proposal',\n        proposalDraft: 'Proposal draft could not be parsed cleanly. Manual review required.',\n        proposalRawResponse: rawOutput,\n        parsingError: error.message\n      }\n    }\n  ];\n}"
      },
