      "id": "624dee58-65de-4b57-beeb-d1be4bf67a26",
      "name": "OpenAI Chat - Analyze RFP Opportunity",
      "credentials": {
        "openAiApi": {
          "id": "REDACTED_OPENAI_CREDENTIAL_ID",
          "name": "OpenAi account"
        }
