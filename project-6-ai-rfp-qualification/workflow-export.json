          "assignments": [
            {
              "id": "e72d5b09-8756-415f-818b-e1ba50d30f60",
              "name": "qualificationPrompt",
              "value": "={{  `You are an AI sales qualification assistant for a B2B automation agency.  Your task is to analyze the following RFP opportunity and return a structured business qualification.  Evaluate the opportunity using these 3 statuses only: - GO - REVIEW - NO_GO  Decision guidance: - GO = strong fit, clear scope, acceptable business potential - REVIEW = partially clear, some uncertainty, needs human review - NO_GO = poor fit, insufficient information, unrealistic scope, or low relevance  Return your answer as valid JSON only with this structure: {   \"qualificationStatus\": \"GO \n REVIEW \n NO_GO\",   \"summary\": \"short business summary\",   \"fitScore\": 0,   \"keyRequirements\": [\"req1\", \"req2\"],   \"risks\": [\"risk1\", \"risk2\"],   \"recommendedNextStep\": \"short recommendation\" }  Opportunity data: Company Name: ${$json.companyName} Industry: ${$json.industry} Country: ${$json.country} Budget: ${$json.budget} Deadline: ${$json.deadline} Project Type: ${$json.projectType} Contact Email: ${$json.contactEmail}  RFP Text: ${$json.rfpText} ` }}",
              "type": "string"
            },
            {
              "id": "2655520a-db58-4f15-bc1d-edd9cfd0dfac",
              "name": "opportunitySummary",
              "value": "={{ $json.companyName + ' | ' + $json.projectType + ' | ' + $json.country }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
