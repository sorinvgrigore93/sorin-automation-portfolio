    {
      "parameters": {
        "jsCode": "const rawOutput = $json.output?.[0]?.content?.[0]?.text || '';\n\nfunction extractJsonString(text) {\n  let cleaned = text.trim();\n\n  // Quitar bloque markdown ```json ... ```\n  cleaned = cleaned.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '');\n  cleaned = cleaned.replace(/\\s*```$/i, '');\n\n  // Si viene con comillas extra al principio y final\n  if (\n    (cleaned.startsWith('\"') && cleaned.endsWith('\"')) ||\n    (cleaned.startsWith(\"'\") && cleaned.endsWith(\"'\"))\n  ) {\n    cleaned = cleaned.slice(1, -1);\n  }\n\n  // Desescapar secuencias comunes\n  cleaned = cleaned\n    .replace(/\\\\\"/g, '\"')\n    .replace(/\\\\n/g, '\\n')\n    .replace(/\\\\t/g, '\\t')\n    .replace(/\\\\\\\\/g, '\\\\');\n\n  // Intentar extraer solo el bloque JSON\n  const firstBrace = cleaned.indexOf('{');\n  const lastBrace = cleaned.lastIndexOf('}');\n\n  if (firstBrace === -1 || lastBrace === -1) {\n    throw new Error('No JSON object found in AI response');\n  }\n\n  return cleaned.slice(firstBrace, lastBrace + 1);\n}\n\ntry {\n  const jsonString = extractJsonString(rawOutput);\n  const parsed = JSON.parse(jsonString);\n\n  return [\n    {\n      json: {\n        qualificationStatus: parsed.qualificationStatus || 'REVIEW',\n        summary: parsed.summary || '',\n        fitScore: parsed.fitScore ?? 0,\n        keyRequirements: Array.isArray(parsed.keyRequirements) ? parsed.keyRequirements : [],\n        risks: Array.isArray(parsed.risks) ? parsed.risks : [],\n        recommendedNextStep: parsed.recommendedNextStep || '',\n        aiRawResponse: rawOutput\n      }\n    }\n  ];\n} catch (error) {\n  return [\n    {\n      json: {\n        qualificationStatus: 'REVIEW',\n        summary: 'AI response could not be parsed cleanly.',\n        fitScore: 0,\n        keyRequirements: [],\n        risks: ['Failed to parse AI output'],\n        recommendedNextStep: 'Manual review required.',\n        aiRawResponse: rawOutput,\n        parsingError: error.message\n      }\n    }\n  ];\n}"
      },
