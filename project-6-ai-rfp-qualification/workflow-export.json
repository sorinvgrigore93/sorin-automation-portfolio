            {
              "id": "d393e981-5f13-40de-941d-2f65864955cb",
              "name": "proposalDraftPrompt",
              "value": "={{ `You are an AI pre-sales assistant for a B2B automation agency.  Write a concise and professional first-draft proposal email for a qualified business opportunity.  Requirements: - Keep the tone professional, clear, and consultative - Write in English - Make it suitable for sending internally to a sales or pre-sales team as a draft foundation - Include a short acknowledgement of the client need - Mention the likely scope based on the opportunity - Mention key requirements - Mention relevant risks or assumptions if needed - End with a suggested next step - Do not invent technical details not present in the input  Use this qualification result:  Qualification Status: ${$json.qualificationStatus} Summary: ${$json.summary} Fit Score: ${$json.fitScore} Key Requirements: ${Array.isArray($json.keyRequirements) ? $json.keyRequirements.join(', ') : ''} Risks: ${Array.isArray($json.risks) ? $json.risks.join(', ') : ''} Recommended Next Step: ${$json.recommendedNextStep}  Return valid JSON only with this structure: {   \"proposalSubject\": \"short subject line\",   \"proposalDraft\": \"full proposal draft text\" }` }}",
              "type": "string"
            },
            {
              "id": "542de357-14fe-42d9-a90c-2d4392481cab",
              "name": "proposalDraftContext",
              "value": "={{ $json.qualificationStatus + ' | score: ' + $json.fitScore }}",
              "type": "string"
            }
          ]
        },
        "options": {}
