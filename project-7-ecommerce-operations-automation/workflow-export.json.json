    {
      "parameters": {
        "sendTo": "redacted@example.com",
        "subject": "=[High Priority] Stock shortage detected - {{ $json.product_sku }}",
        "message": "=<div style=\"font-family: Arial, sans-serif; max-width: 650px; margin: 0 auto; border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; background-color: #ffffff;\">\n\n  <div style=\"background-color: #111827; color: #ffffff; padding: 20px;\">\n    <h2 style=\"margin: 0;\">Inventory Alert</h2>\n    <p style=\"margin: 6px 0 0 0; color: #d1d5db;\">\n      Stock shortage detected for a customer order\n    </p>\n  </div>\n\n  <div style=\"padding: 24px;\">\n\n    <div style=\"background-color: #fff7ed; border-left: 5px solid #f97316; padding: 14px 16px; margin-bottom: 22px;\">\n      <strong>Action required:</strong> This order cannot be processed because there is not enough stock available.\n    </div>\n\n    <h3 style=\"margin-top: 0; color: #111827;\">Order Details</h3>\n\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px;\">\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; color: #6b7280;\">Order ID</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\"><strong>{{ $json.order_id }}</strong></td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; color: #6b7280;\">Product</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\">{{ $json.product_name }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; color: #6b7280;\">SKU</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\"><strong>{{ $json.product_sku }}</strong></td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; color: #6b7280;\">Requested Quantity</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\">{{ $json.requested_quantity }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; color: #6b7280;\">Current Stock</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb;\">{{ $json.current_stock }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; color: #6b7280;\">Missing Quantity</td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #e5e7eb; color: #dc2626;\"><strong>{{ $json.missing_quantity }}</strong></td>\n      </tr>\n    </table>\n\n    <div style=\"background-color: #f9fafb; padding: 16px; border-radius: 8px; margin-bottom: 20px;\">\n      <strong>Recommended next step:</strong>\n      <p style=\"margin: 8px 0 0 0;\">\n        Review inventory levels and contact the supplier or purchasing team to restock this product.\n      </p>\n    </div>\n\n    <p style=\"color: #6b7280; font-size: 14px;\">\n      Internal note: {{ $json.internal_alert }}\n    </p>\n\n  </div>\n\n  <div style=\"background-color: #f3f4f6; padding: 14px 24px; color: #6b7280; font-size: 13px;\">\n    Automated notification generated by n8n — Order & Inventory Management Automation\n  </div>\n\n</div>",
