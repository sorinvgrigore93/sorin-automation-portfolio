    {
      "parameters": {
        "jsCode": "const stockCheck = $json;\n\nconst missingQuantity = stockCheck.requested_quantity - stockCheck.current_stock;\n\nreturn [\n  {\n    json: {\n      success: false,\n      status: \"OUT_OF_STOCK\",\n      order_id: stockCheck.order_id,\n      customer_email: stockCheck.customer_email,\n      product_sku: stockCheck.product_sku,\n      product_name: stockCheck.product_name,\n      requested_quantity: stockCheck.requested_quantity,\n      current_stock: stockCheck.current_stock,\n      missing_quantity: missingQuantity,\n      supplier_email: stockCheck.supplier_email,\n      message: \"Order cannot be processed because there is not enough stock.\",\n      internal_alert: `Stock shortage for ${stockCheck.product_sku}. Requested: ${stockCheck.requested_quantity}, available: ${stockCheck.current_stock}, missing: ${missingQuantity}.`\n    }\n  }\n];"
      },
