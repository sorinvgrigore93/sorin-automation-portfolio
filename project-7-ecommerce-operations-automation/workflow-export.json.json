      "parameters": {
        "jsCode": "const order = $json.body;\n\nconst requiredFields = [\n  'order_id',\n  'customer_name',\n  'customer_email',\n  'product_sku',\n  'quantity'\n];\n\nconst missingFields = requiredFields.filter(field => {\n  return order[field] === undefined || order[field] === null || order[field] === '';\n});\n\nconst isQuantityValid = typeof order.quantity === 'number' && order.quantity > 0;\n\nreturn [\n  {\n    json: {\n      ...order,\n      is_valid_order: missingFields.length === 0 && isQuantityValid,\n      missing_fields: missingFields,\n      validation_error: missingFields.length > 0\n        ? `Missing required fields: ${missingFields.join(', ')}`\n        : !isQuantityValid\n          ? 'Quantity must be a number greater than 0'\n          : null\n    }\n  }\n];"
      },
