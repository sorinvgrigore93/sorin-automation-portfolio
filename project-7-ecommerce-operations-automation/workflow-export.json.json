    {
      "parameters": {
        "jsCode": "const inventory = $json;\n\nconst order = $('Code - Validate Order Data').first().json;\n\nconst requestedQuantity = Number(order.quantity);\nconst currentStock = Number(inventory.stock_available);\nconst reorderLevel = Number(inventory.reorder_level);\n\nconst newStock = currentStock - requestedQuantity;\n\nconst hasEnoughStock = currentStock >= requestedQuantity;\nconst isLowStockAfterOrder = hasEnoughStock && newStock <= reorderLevel;\n\nreturn [\n  {\n    json: {\n      order_id: order.order_id,\n      customer_name: order.customer_name,\n      customer_email: order.customer_email,\n      product_sku: order.product_sku,\n      product_name: inventory.product_name,\n      requested_quantity: requestedQuantity,\n      current_stock: currentStock,\n      new_stock: hasEnoughStock ? newStock : currentStock,\n      reorder_level: reorderLevel,\n      supplier_email: inventory.supplier_email,\n      has_enough_stock: hasEnoughStock,\n      is_low_stock_after_order: isLowStockAfterOrder,\n      stock_status: hasEnoughStock ? 'AVAILABLE' : 'OUT_OF_STOCK',\n      message: hasEnoughStock\n        ? 'Stock available. Order can be processed.'\n        : 'Not enough stock. Supplier notification required.'\n    }\n  }\n];"
      },
