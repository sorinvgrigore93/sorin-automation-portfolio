    \{\
      "parameters": \{\
        "jsCode": "// Calculate Weekly Metrics (previous week: Mon-Sun)\\nconst TZ = 'Europe/Madrid'; // solo informativo aqu\'ed\\nconst VALID_STATUS = 'validated';\\n\\nfunction toISODate(d) \{\\n  const yyyy = d.getFullYear();\\n  const mm = String(d.getMonth() + 1).padStart(2, '0');\\n  const dd = String(d.getDate()).padStart(2, '0');\\n  return `$\{yyyy\}-$\{mm\}-$\{dd\}`;\\n\}\\n\\nfunction startOfWeekMonday(date) \{\\n  const d = new Date(date);\\n  d.setHours(0, 0, 0, 0);\\n  const day = d.getDay();\\n  const diff = (day === 0 ? -6 : 1) - day;\\n  d.setDate(d.getDate() + diff);\\n  return d;\\n\}\\n\\nconst now = new Date();\\nconst thisWeekStart = startOfWeekMonday(now);\\nconst prevWeekStart = new Date(thisWeekStart);\\nprevWeekStart.setDate(prevWeekStart.getDate() - 7);\\n\\nconst prevWeekEnd = new Date(thisWeekStart);\\nprevWeekEnd.setDate(prevWeekEnd.getDate() - 1);\\nprevWeekEnd.setHours(23, 59, 59, 999);\\n\\nconst weekStartISO = toISODate(prevWeekStart);\\nconst weekEndISO = toISODate(prevWeekEnd);\\n\\nconst rows = $input.all().map(i => i.json);\\n\\nconst rowsFiltered = rows.filter(r => \{\\n  const created = (r.created_at || '').toString().trim();\\n  return created >= weekStartISO && created <= weekEndISO;\\n\});\\n\\nlet total = rowsFiltered.length;\\nlet validated = 0;\\n\\nconst byCountry = \{\};\\nconst byProduct = \{\};\\n\\nfor (const r of rowsFiltered) \{\\n  const status = (r.status || '').toString().trim().toLowerCase();\\n  if (status === VALID_STATUS) validated++;\\n\\n  const country = (r.country || 'UNKNOWN').toString().trim().toUpperCase();\\n  const product = (r.product || 'UNKNOWN').toString().trim();\\n\\n  byCountry[country] = (byCountry[country] || 0) + 1;\\n  byProduct[product] = (byProduct[product] || 0) + 1;\\n\}\\n\\nfunction topEntries(obj, limit = 10) \{\\n  return Object.entries(obj)\\n    .sort((a, b) => b[1] - a[1])\\n    .slice(0, limit)\\n    .map(([key, count]) => (\{ key, count \}));\\n\}\\n\\nconst result = \{\\n  meta: \{\\n    reportName: 'Weekly Sales Leads Report',\\n    weekStart: weekStartISO,\\n    weekEnd: weekEndISO,\\n    runAt: now.toISOString(),\\n  \},\\n  metrics: \{\\n    total,\\n    validated,\\n    byCountry,\\n    byProduct,\\n    topCountries: topEntries(byCountry, 5),\\n    topProducts: topEntries(byProduct, 5),\\n  \},\\n  rowsFilteredCount: rowsFiltered.length,\\n\};\\n\\nreturn [\{ json: result \}];"\
      \},\
