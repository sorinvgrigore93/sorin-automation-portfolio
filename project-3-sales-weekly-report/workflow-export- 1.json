        "jsCode": "const data = $input.first().json;\\n\\nconst \{ reportName, weekStart, weekEnd \} = data.meta;\\nconst \{ total, validated, topCountries, topProducts \} = data.metrics;\\n\\nfunction bulletList(items) \{\\n  if (!items?.length) return '- (sin datos)';\\n  return items.map(i => `- $\{i.key\}: $\{i.count\}`).join('\\\\n');\\n\}\\n\\nconst subject = `$\{reportName\} \'97 $\{weekStart\} to $\{weekEnd\}`;\\n\\nconst body =\\n`$\{reportName\}\\nWeek: $\{weekStart\} \uc0\u8594  $\{weekEnd\}\\n\\nSummary\\n- Total leads: $\{total\}\\n- Validated leads: $\{validated\}\\n\\nTop Countries\\n$\{bulletList(topCountries)\}\\n\\nTop Products\\n$\{bulletList(topProducts)\}\\n\\nGenerated automatically by n8n.\\n`;\\n\\nreturn [\{\\n  json: \{\\n    subject,\\n    body,\\n    meta: data.meta,\\n    metrics: data.metrics\\n  \}\\n\}];"\
