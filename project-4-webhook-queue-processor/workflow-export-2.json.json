      "parameters": {
        "jsCode": "let payloadObj = {};\ntry {\n  payloadObj = typeof $json.payload === 'string' ? JSON.parse($json.payload) : ($json.payload ?? {});\n} catch (e) {\n  payloadObj = {};\n}\n\nconst email = (payloadObj.email ?? \"\").toString().trim().toLowerCase();\nconst country = (payloadObj.country ?? \"\").toString().trim().toUpperCase();\nconst source = (payloadObj.source ?? \"\").toString().trim();\n\nreturn [{\n  json: {\n    ...$json,\n    lead: {\n      external_id: payloadObj.external_id ?? null,\n      email,\n      country,\n      source,\n    }\n  }\n}];"
      },
