    {
      "parameters": {
        "jsCode": "const now = Date.now();\n\n// attempts/maxAttempts vienen del item de la cola (siempre existen ahí)\nconst attempts = Number($json.attempts ?? 0) + 1;\nconst maxAttempts = Number($json.max_attempts ?? 5);\n\n// backoff: 30s, 60s, 120s, 240s, 480s (máx 900s)\nconst delaySec = Math.min(900, Math.pow(2, attempts - 1) * 30);\nconst nextRetryAt = new Date(now + delaySec * 1000).toISOString();\n\n// Error del nodo de Google Sheets (en tu caso es string)\nconst gsError = $node[\"GS - Append Row (Leads)\"].json.error;\nconst errorMsg = (typeof gsError === \"string\" && gsError.length)\n  ? gsError\n  : JSON.stringify(gsError || {}) || \"Unknown error\";\n\n// ID real de la fila en la cola (NO depende del $json actual)\nconst queueId = $node[\"DT - Update Row (Lock + Processing)\"].json.id;\n\nconst shouldRetry = attempts < maxAttempts;\n\nreturn [{\n  json: {\n    ...$json,\n    queue_id: queueId,\n    attempts,\n    next_retry_at: nextRetryAt,\n    last_error: errorMsg,\n    next_status: shouldRetry ? \"queued\" : \"failed\",\n    shouldRetry,\n  }\n}];"
      },
