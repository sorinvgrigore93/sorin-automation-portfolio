        "jsCode": "const ownersRaw = $input.all().map(i => i.json);\\n\\n// Normaliza boolean \\"active\\" (porque Sheets a veces devuelve true/TRUE/\\"TRUE\\"/1)\\nconst isActive = (v) => \{\\n  if (v === true) return true;\\n  if (v === false) return false;\\n  const s = String(v ?? \\"\\").trim().toLowerCase();\\n  return [\\"true\\", \\"1\\", \\"yes\\", \\"y\\"].includes(s);\\n\};\\n\\n// Si last_assigned_at est\'e1 vac\'edo o inv\'e1lido \uc0\u8594  lo tratamos como el m\'e1s antiguo\\nconst toTime = (v) => \{\\n  if (!v) return 0;\\n  const t = Date.parse(v);\\n  return Number.isNaN(t) ? 0 : t;\\n\};\\n\\n// 1) Filtra activos\\nconst owners = ownersRaw.filter(o => isActive(o.active));\\n\\n// Guardrail: si no hay owners activos, devolvemos un error \'93controlado\'94\\nif (owners.length === 0) \{\\n  return [\{\\n    json: \{\\n      error: \\"NO_ACTIVE_OWNERS\\",\\n      now_iso: new Date().toISOString()\\n    \}\\n  \}];\\n\}\\n\\n// 2) Ordena por last_assigned_at ASC (el m\'e1s viejo primero)\\nowners.sort((a, b) => toTime(a.last_assigned_at) - toTime(b.last_assigned_at));\\n\\nconst chosen = owners[0];\\n\\nreturn [\{\\n  json: \{\\n    owner_id: chosen.owner_id,\\n    owner_name: chosen.name,\\n    owner_row_number: chosen.row_number,   // clave para actualizar Owners\\n    now_iso: new Date().toISOString()\\n  \}\\n\}];"\
      \},\
